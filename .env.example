# Mangou AI Studio - Example Config

# 核心：物理隔离模式
NEXT_PUBLIC_MANGO_MODE="local"
NEXT_PUBLIC_VFS_ROOT="./workspace"

# LLM 核心 (用户需自行配置自己的 Key 以驱动 AI 生成)
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"

# ACP Agent 连接
# ACP_WS_URL="ws://localhost:8090/acp"
# ACP_AUTH_METHOD_ID="oauth-iflow"
# NEXT_PUBLIC_ACP_AUTH_METHOD_ID="oauth-iflow"
# ACP_AUTO_START="true"
# ACP_START_COMMAND="iflow --experimental-acp --port 8090"
# ACP_START_CWD="."
# ACP_START_TIMEOUT_MS="30000"

# 资源生成上游 (默认: aigc)
# RESOURCE_PROVIDER="aigc"

# 本地环境变量 (Mock 环境)
NODE_ENV="development"
