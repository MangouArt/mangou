{
  "name": "@mangou/core",
  "version": "1.0.0",
  "private": false,
  "description": "Mangou AI Studio - Lightweight Open Source Core",
  "license": "FSL-1.1-Apache-2.0",
  "homepage": "https://www.mangou.art",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MangouArt/mangou.git"
  },
  "bugs": {
    "url": "https://github.com/MangouArt/mangou/issues",
    "email": "mangou@mangou.art"
  },
  "keywords": [
    "ai",
    "comics",
    "storyboard",
    "agent",
    "skill",
    "local-first",
    "aigc",
    "claude-skill",
    "mcp-plugin",
    "mangou",
    "video-generation"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    "bundled-skills",
    "scripts",
    "skill-src",
    "src",
    "public",
    "dist",
    "workspace_template",
    "styles",
    "tsconfig.json",
    "index.html",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:skill": "node scripts/build-skill.mjs",
    "prepack": "npm run build && npm run build:skill",
    "preview": "vite preview",
    "start": "TSX_TSCONFIG_PATH=./tsconfig.json node --import tsx scripts/http-server.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm test && npm run build && npm run build:skill",
    "workspace:init": "node scripts/init-workspace.mjs",
    "workspace:reset:test": "node scripts/reset-test-workspace.mjs",
    "project:create": "node scripts/create-project.mjs",
    "web:start": "node scripts/start-web.mjs",
    "web:stop": "node scripts/stop-web.mjs",
    "web:status": "node scripts/web-status.mjs",
    "aigc:run": "node scripts/aigc-runner.mjs",
    "test": "vitest run",
    "test:frontend": "vitest run src/lib/frontend/vite-build.test.ts",
    "test:web": "vitest run src/lib/web/web-control.test.ts",
    "test:bltai": "vitest run src/lib/aigc/bltai-mvp.test.ts",
    "test:skill": "vitest run src/lib/skill/skill-packaging.test.ts",
    "test:skill:zip": "node scripts/test-skill-zip.mjs",
    "test:skill:aigc:heavy": "node scripts/test-aigc-heavy.mjs",
    "prepare": "husky install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-query": "5.95.2",
    "antd": "6.3.3",
    "axios": "^1.14.0",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "11.18.2",
    "https-proxy-agent": "^8.0.0",
    "js-yaml": "4.1.1",
    "lucide-react": "0.563.0",
    "openai": "4.104.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "6.30.3",
    "sharp": "0.34.5",
    "tailwind-merge": "2.6.1",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.20.5",
    "undici": "^7.24.6",
    "uuid": "13.0.0",
    "yaml": "2.8.3",
    "zod": "3.25.76",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "18.19.130",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "husky": "^8.0.0",
    "postcss": "8.4.31",
    "tailwindcss": "4.2.2",
    "typescript": "5.6.3",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  }
}
