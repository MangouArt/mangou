{
  "name": "@mangou/core",
  "version": "1.0.0",
  "private": false,
  "description": "Mangou AI Studio - Lightweight Open Source Core",
  "license": "FSL-1.1-Apache-2.0",
  "homepage": "https://www.mangou.art",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MangouArt/mangou.git"
  },
  "bugs": {
    "url": "https://github.com/MangouArt/mangou/issues",
    "email": "mangou@mangou.art"
  },
  "keywords": [
    "ai",
    "comics",
    "storyboard",
    "agent",
    "skill",
    "local-first",
    "aigc",
    "claude-skill",
    "mcp-plugin",
    "mangou",
    "video-generation"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "files": [
    "bundled-skills",
    "skills",
    "skill-src",
    "src",
    "public",
    "dist",
    "workspace_template",
    "styles",
    "tsconfig.json",
    "index.html",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:skill": "bun src/main.ts build:skill --skill mangou",
    "build:dashboard:package": "node scripts/sync-dashboard-package.mjs",
    "prepack": "bun run build && bun run build:skill",
    "preview": "vite preview",
    "start": "bun run mangou -- server start",
    "mangou": "bun run src/main.ts",
    "build:bin": "bun build --compile src/main.ts --outfile bin/mangou",
    "build:assets": "mkdir -p src/assets && cd workspace_template && zip -r ../src/assets/workspace_template.zip .",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun run test && bun run build && bun run build:skill",
    "project:init": "bun run mangou -- project init",
    "project:stitch": "bun run mangou -- project stitch",
    "storyboard:generate": "bun run mangou -- storyboard generate",
    "storyboard:split": "bun run mangou -- storyboard split",
    "asset:generate": "bun run mangou -- asset generate",
    "server:start": "bun run mangou -- server start",
    "workspace:reset:test": "bun src/logic/reset-test-workspace.ts",
    "test": "vitest run",
    "test:skill": "vitest run test/core/skill-packaging.test.ts",
    "test:skill:zip": "bun src/logic/pack-full.ts",
    "test:skill:aigc:heavy": "bun src/logic/test-aigc-heavy.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-query": "5.95.2",
    "@vercel/analytics": "^2.0.1",
    "antd": "6.3.3",
    "axios": "^1.14.0",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "11.18.2",
    "https-proxy-agent": "^8.0.0",
    "js-yaml": "4.1.1",
    "lucide-react": "0.563.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "6.30.3",
    "tailwind-merge": "2.6.1",
    "tailwindcss-animate": "1.0.7",
    "undici": "^7.24.6",
    "uuid": "13.0.0",
    "yaml": "2.8.3",
    "zod": "3.25.76",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/bun": "^1.3.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "husky": "^8.0.0",
    "postcss": "8.4.31",
    "tailwindcss": "4.2.2",
    "typescript": "5.6.3",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  }
}
